# Normaliza fim de linha: LF no repositório, conversão automática no checkout.
* text=auto eol=lf

# Arquivos do ecossistema .NET/Windows que devem permanecer em CRLF.
*.sln       text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf

# Tratados como binário (sem normalização nem diff de texto).
*.xlsx      binary
*.png       binary
*.jpg       binary
*.ico       binary
